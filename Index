<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Labor Union Organization</title>

<!-- INTERNAL CSS -->
<style>
  /* =========
     THEME
  ========= */
  :root {
    --primary: #003366;
    --primary-600: #0a4a94;
    --secondary: #14171a;
    --accent: #66aaff;
    --light-bg: #f4f6f9;
    --panel: #ffffff;
    --text-dark: #222;
    --muted: #6b7280;
    --ring: #9cc7ff;
    --radius: 14px;
    --transition: 220ms cubic-bezier(.2,.8,.2,1);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --light-bg: #0c0f13;
      --panel: #11161c;
      --text-dark: #e6eef6;
      --secondary: #0a0d10;
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }

  /* =========
     BASE
  ========= */
  * { box-sizing: border-box; }
  html, body { height: 100%; }

  body {
    font-family: "Segoe UI", system-ui, -apple-system, Arial, sans-serif;
    margin: 0;
    background: radial-gradient(1200px 800px at 15% 10%, rgba(102,170,255,.08), transparent 60%),
                radial-gradient(900px 700px at 90% 20%, rgba(10,74,148,.10), transparent 55%),
                var(--light-bg);
    color: var(--text-dark);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    animation: bodyFadeIn .6s ease-out both;
  }

  @keyframes bodyFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* =========
     HEADER
  ========= */
  header {
    position: relative;
    color: white;
    padding: 56px 20px 48px;
    text-align: center;
    overflow: clip;
    background:
      linear-gradient(180deg, rgba(0,0,0,.0) 0%, rgba(0,0,0,.0) 100%),
      linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
    box-shadow: 0 18px 40px rgba(0,0,0,.18);
    isolation: isolate;
  }

  /* Subtle animated accent at the top edge */
  header::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(1200px 200px at 50% 0%, rgba(255,255,255,.18), transparent 60%);
    mix-blend-mode: screen;
    animation: sweep 8s linear infinite;
    opacity: .5;
    pointer-events: none;
  }

  @keyframes sweep {
    0% { transform: translateX(-20%); }
    50% { transform: translateX(20%); }
    100% { transform: translateX(-20%); }
  }

  header h1 {
    margin: 0 0 8px 0;
    font-size: clamp(1.8rem, 2.6vw, 2.6rem);
    letter-spacing: .4px;
  }

  header p {
    margin: 0;
    opacity: .95;
    font-weight: 500;
  }

  /* =========
     NAV
  ========= */
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--secondary) 90%, black 10%);
    padding: 12px 18px;
    display: flex;
    justify-content: center;
    gap: 10px 18px;
    border-bottom: 1px solid rgba(255,255,255,.06);
    backdrop-filter: saturate(140%) blur(8px);
  }

  /* Stylish button paths via animated conic border + underline trail */
  .nav-btn {
    --btn-bg: transparent;
    --btn-fg: #fff;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    padding: 10px 14px;
    color: var(--btn-fg);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: .2px;
    border-radius: 10px;
    isolation: isolate;
    transition: transform var(--transition), color var(--transition);
  }

  /* Animated underline path */
  .nav-btn::after {
    content: "";
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 6px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }

  /* Conic border that animates on hover/focus */
  .nav-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;           /* border thickness */
    border-radius: 12px;
    background:
      conic-gradient(from 180deg at 50% 50%,
        rgba(255,255,255,.0),
        rgba(255,255,255,.35),
        rgba(255,255,255,.0) 60%);
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: .0;
    transition: opacity var(--transition), transform var(--transition);
    pointer-events: none;
  }

  .nav-btn:hover,
  .nav-btn:focus-visible {
    color: #eaf2ff;
    transform: translateY(-1px);
  }

  .nav-btn:hover::after,
  .nav-btn:focus-visible::after {
    transform: scaleX(1);
  }

  .nav-btn:hover::before,
  .nav-btn:focus-visible::before {
    opacity: 1;
    transform: rotate(3deg) scale(1.02);
  }

  .nav-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ring) 70%, transparent);
    border-radius: 12px;
  }

  /* =========
     MAIN / SECTION
  ========= */
  main, section {
    padding: 36px 20px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .card {
    background: var(--panel);
    border-radius: var(--radius);
    padding: clamp(20px, 3.6vw, 28px);
    box-shadow:
      0 1px 0 rgba(0,0,0,.04),
      0 16px 40px rgba(0,0,0,.08);
    border: 1px solid color-mix(in srgb, var(--panel) 92%, #9cc7ff 8%);
    position: relative;
    overflow: clip;
    animation: floatIn .5s var(--transition) both .05s;
  }

  /* subtle decorative gradient edge */
  .card::before {
    content: "";
    position: absolute;
    inset: -1px;
    background:
      linear-gradient(180deg, rgba(102,170,255,.14), transparent 30%),
      linear-gradient(0deg, rgba(255,255,255,.06), transparent 40%);
    pointer-events: none;
  }

  @keyframes floatIn {
    from { opacity: 0; transform: translateY(10px) scale(.98); }
    to   { opacity: 1; transform: translateY(0)   scale(1); }
  }

  h2 {
    margin: 0 0 10px 0;
    color: var(--primary);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
  }

  p.lead {
    margin: 0;
    font-size: 1.05rem;
    color: var(--text-dark);
  }

  /* =========
     CTA BUTTON (Stylish Path Border)
  ========= */
  .cta {
    --glow: #7fb6ff;
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    margin-top: 20px;
    padding: 12px 18px;
    color: #0b1f3a;
    background: linear-gradient(180deg, #e9f2ff, #d7e9ff);
    border-radius: 12px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: .25px;
    position: relative;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  /* Animated path border around the button */
  .cta::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 14px;
    padding: 1.5px;
    background:
      conic-gradient(from var(--angle, 0deg),
        rgba(127,182,255, .0) 0deg,
        rgba(127,182,255, .6) 90deg,
        rgba(127,182,255, .0) 180deg,
        rgba(127,182,255, .6) 270deg,
        rgba(127,182,255, .0) 360deg);
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    animation: spin 3s linear infinite;
  }

  @keyframes spin {
    to { --angle: 360deg; }
  }

  .cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 26px rgba(10, 74, 148, .20);
  }

  .cta:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ring) 70%, transparent), 0 8px 26px rgba(10, 74, 148, .20);
  }

  /* =========
     FOOTER
  ========= */
  footer {
    background: linear-gradient(0deg, var(--primary) 0%, var(--primary-600) 100%);
    color: white;
    text-align: center;
    padding: 18px;
    margin-top: 36px;
    font-size: .95rem;
    letter-spacing: .3px;
    border-top: 1px solid rgba(255,255,255,.12);
  }

  /* =========
     UTILS
  ========= */
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding-inline: 20px;
  }
</style>

