<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Union Loan System | Secure Application</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary: #003366;
      --primary-dark: #001f3d;
      --accent: #66aaff;
      --bg: #f0f4f8;
      --white: #ffffff;
      --text: #334155;
      --error: #ef4444;
      --radius: 16px;
      --shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background-color: var(--bg);
      color: var(--text);
      margin: 0;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    header {
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      color: white;
      padding: 50px 20px 80px;
      text-align: center;
    }

    header h1 {
      margin: 0;
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    header p {
      opacity: 0.8;
      margin-top: 8px;
    }

    .container {
      max-width: 650px;
      width: 90%;
      margin: -50px auto 50px;
    }

    .loan-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 40px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(255,255,255,0.8);
    }

    .form-group {
      margin-bottom: 24px;
      position: relative;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    label {
      display: block;
      font-weight: 600;
      margin-bottom: 8px;
      font-size: 0.9rem;
      color: var(--primary);
    }

    .input-wrapper {
      position: relative;
    }

    .input-wrapper i {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      transition: color 0.3s;
    }

    input, textarea {
      width: 100%;
      padding: 12px 12px 12px 42px;
      border: 2px solid #e2e8f0;
      border-radius: 10px;
      font-size: 1rem;
      box-sizing: border-box;
      transition: all 0.3s ease;
      background: #f8fafc;
    }

    textarea {
      padding-left: 14px;
      height: 100px;
      resize: none;
    }

    input:focus, textarea:focus {
      outline: none;
      border-color: var(--accent);
      background: var(--white);
      box-shadow: 0 0 0 4px rgba(102, 170, 255, 0.1);
    }

    input:focus + i {
      color: var(--accent);
    }

    .amount-display {
      background: #f1f5f9;
      padding: 15px;
      border-radius: 10px;
      text-align: center;
      margin-bottom: 24px;
      border: 1px dashed var(--accent);
    }

    .amount-display span {
      display: block;
      font-size: 0.8rem;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 5px;
    }

    .amount-display strong {
      font-size: 1.8rem;
      color: var(--primary);
    }

    .btn-submit {
      width: 100%;
      background: linear-gradient(to right, var(--primary), #004d99);
      color: white;
      border: none;
      padding: 16px;
      border-radius: 12px;
      font-size: 1.1rem;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
    }

    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 15px -3px rgba(0, 51, 102, 0.3);
    }

    .btn-submit:active {
      transform: translateY(0);
    }

    @media (max-width: 600px) {
      .form-row { grid-template-columns: 1fr; }
      .loan-card { padding: 25px; }
    }
  </style>
</head>
<body>

<header>
  <h1>Union Loan Application</h1>
  <p>Financial assistance designed for our members</p>
</header>

<div class="container">
  <div class="loan-card">
    <form id="loanForm">
      
      <div class="form-row">
        <div class="form-group">
          <label>Member Name</label>
          <div class="input-wrapper">
            <i class="fas fa-user"></i>
            <input type="text" placeholder="e.g. Juan Dela Cruz" required>
          </div>
        </div>
        
        <div class="form-group">
          <label>Employee ID</label>
          <div class="input-wrapper">
            <i class="fas fa-id-badge"></i>
            <input type="text" placeholder="e.g. 2026-001" required>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label>Loan Amount (₱)</label>
        <div class="input-wrapper">
          <i class="fas fa-money-bill-wave"></i>
          <input type="number" id="loanAmount" placeholder="0.00" required>
        </div>
      </div>

      <div class="amount-display">
        <span>Estimated Request</span>
        <strong id="displayAmount">₱ 0.00</strong>
      </div>

      <div class="form-group">
        <label>Purpose of Loan</label>
        <textarea placeholder="Please describe how this loan will be used..."></textarea>
      </div>

      <button type="submit" class="btn-submit">
        Submit Loan Request <i class="fas fa-paper-plane"></i>
      </button>
    </form>
  </div>
</div>

<script>
  // Dynamic currency formatter for interactivity
  const amountInput = document.getElementById('loanAmount');
  const display = document.getElementById('displayAmount');

  amountInput.addEventListener('input', function(e) {
    const val = e.target.value;
    if (val) {
      const formatted = new Intl.NumberFormat('en-PH', {
        style: 'currency',
        currency: 'PHP'
      }).format(val);
      display.textContent = formatted;
    } else {
      display.textContent = "₱ 0.00";
    }
  });

  document.getElementById('loanForm').addEventListener('submit', function(e) {
    e.preventDefault();
    alert('Application submitted successfully! Our treasurer will review your request.');
  });
</script>

</body>
</html>
