<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CBA Laws | Resource Center</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary: #003366;
      --accent: #66aaff;
      --bg: #f4f7fa;
      --text: #1f2937;
      --white: #ffffff;
      --radius: 12px;
      --shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      line-height: 1.6;
    }

    header {
      background: linear-gradient(135deg, var(--primary), #001f3d);
      color: white;
      padding: 60px 20px;
      text-align: center;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    header h1 {
      margin: 0;
      font-size: 2.5rem;
      letter-spacing: -1px;
    }

    header p {
      opacity: 0.8;
      margin-top: 10px;
      font-weight: 300;
    }

    .container {
      max-width: 1000px;
      margin: -40px auto 40px;
      padding: 0 20px;
    }

    section {
      background: var(--white);
      border-radius: var(--radius);
      padding: 40px;
      box-shadow: var(--shadow);
      margin-bottom: 30px;
    }

    h2 {
      font-size: 1.5rem;
      border-left: 4px solid var(--accent);
      padding-left: 15px;
      margin-bottom: 25px;
      color: var(--primary);
    }

    /* --- Document Grid --- */
    .doc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .doc-card {
      border: 1px solid #e5e7eb;
      border-radius: var(--radius);
      padding: 20px;
      display: flex;
      align-items: center;
      transition: all 0.3s ease;
      text-decoration: none;
      color: inherit;
    }

    .doc-card:hover {
      transform: translateY(-5px);
      border-color: var(--accent);
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    .doc-icon {
      font-size: 2rem;
      color: #ef4444; /* PDF Red */
      margin-right: 15px;
    }

    .doc-info span {
      display: block;
      font-weight: 600;
    }

    .doc-info small {
      color: #6b7280;
    }

    /* --- Upload Section --- */
    .upload-box {
      border: 2px dashed #d1d5db;
      border-radius: var(--radius);
      padding: 30px;
      text-align: center;
      transition: background 0.3s ease;
      position: relative;
    }

    .upload-box:hover {
      background: #f9fafb;
      border-color: var(--accent);
    }

    input[type="file"] {
      display: none;
    }

    .file-label {
      cursor: pointer;
      display: block;
    }

    .file-label i {
      font-size: 3rem;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .btn-upload {
      background: var(--primary);
      color: white;
      border: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 20px;
      transition: background 0.2s;
    }

    .btn-upload:hover {
      background: #004d99;
    }

    @media (max-width: 600px) {
      header h1 { font-size: 1.8rem; }
      section { padding: 20px; }
    }
  </style>
</head>
<body>

<header>
  <h1>Collective Bargaining Agreement</h1>
  <p>Legal Framework & Labor Code Resources</p>
</header>

<div class="container">
  <section>
    <h2>Official Documents</h2>
    <div class="doc-grid">
      <a href="documents/CBA2026.pdf" class="doc-card" download>
        <div class="doc-icon"><i class="fas fa-file-pdf"></i></div>
        <div class="doc-info">
          <span>CBA Agreement 2026</span>
          <small>PDF • 2.4 MB</small>
        </div>
      </a>

      <a href="documents/LaborCode.pdf" class="doc-card" download>
        <div class="doc-icon"><i class="fas fa-file-pdf"></i></div>
        <div class="doc-info">
          <span>National Labor Code</span>
          <small>PDF • 5.1 MB</small>
        </div>
      </a>
    </div>

    <h2>Administrative Upload</h2>
    <form class="upload-box">
      <label for="file-upload" class="file-label">
        <i class="fas fa-cloud-upload-alt"></i>
        <p><strong>Click to select</strong> or drag and drop<br>
        <small>Supported formats: PDF, DOCX (Max 10MB)</small></p>
      </label>
      <input id="file-upload" type="file">
      <button type="submit" class="btn-upload">Upload Document</button>
    </form>
  </section>
</div>

<script>
  // Simple interaction to show filename after selection
  const fileInput = document.getElementById('file-upload');
  const labelText = document.querySelector('.file-label p strong');

  fileInput.addEventListener('change', function() {
    if (this.files && this.files.length > 0) {
      labelText.textContent = "Selected: " + this.files[0].name;
      labelText.style.color = "#66aaff";
    }
  });
</script>

</body>
</html>
