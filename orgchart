  <!-- Minimal JS: filter + expand/collapse + core roles toggle -->
  <script>
    (function(){
      const filter = document.getElementById('filter');
      const tree = document.getElementById('orgTree');
      const nodes = [...tree.querySelectorAll('.node')];
      const coreOnly = document.getElementById('coreOnly');
      const expandAll = document.getElementById('expandAll');
      const collapseAll = document.getElementById('collapseAll');

      function norm(s){ return (s||"").toLowerCase(); }
      function match(node, q){ if(!q) return true; return norm(node.innerText).includes(q); }
      function setHidden(el, hidden){ el.classList.toggle('hidden', !!hidden); }
      function clearMatch(){
        nodes.forEach(n => n.classList.remove('match'));
        tree.querySelectorAll('li').forEach(li => li.classList.remove('hidden'));
      }
      function showAncestors(li){
        let p = li.parentElement;
        while(p && p !== tree){
          if(p.tagName === 'UL'){ p = p.parentElement; continue; }
          if(p.tagName === 'LI'){ p.classList.remove('hidden'); }
          p = p.parentElement;
        }
      }

      filter.addEventListener('input', ()=>{
        const q = norm(filter.value.trim());
        if(!q){ clearMatch(); return; }
        tree.querySelectorAll('li').forEach(li => setHidden(li, true));
        nodes.forEach(n => n.classList.remove('match'));
        nodes.forEach(node=>{
          const li = node.closest('li');
          if(match(node,q)){
            node.classList.add('match');
            li.classList.remove('hidden');
            showAncestors(li);
          }
        });
      });

      coreOnly.addEventListener('change', (e)=>{
        document.body.classList.toggle('core-only', e.target.checked);
      });

      expandAll.addEventListener('click', ()=>{
        tree.querySelectorAll('details').forEach(d => d.open = true);
      });
      collapseAll.addEventListener('click', ()=>{
        tree.querySelectorAll('details').forEach(d => d.open = false);
      });
    })();
  </script>
